<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_playful"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_panel_soft"
                android:contentDescription="Назад"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                style="@style/Text.ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Профиль" />

            <ImageButton
                android:id="@+id/btnShop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_panel_soft"
                android:contentDescription="Магазин"
                android:padding="10dp"
                android:src="@drawable/ic_store" />
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/stroke_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/circle_avatar"
                    android:clipToOutline="true"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/stickman_face" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvUsername"
                        style="@style/Text.CardTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Имя пользователя" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsernameEdit"
                        style="@style/Text.CardTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textPersonName"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnEditUsername"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Изменить имя"
                        android:padding="6dp"
                        android:src="@drawable/ic_edit" />

                    <ImageButton
                        android:id="@+id/btnSaveUsername"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Сохранить имя"
                        android:padding="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnCancelUsername"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Отменить изменение имени"
                        android:padding="6dp"
                        android:src="@drawable/ic_close"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    style="@style/Text.BodySecondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Уровень читателя • 1200 XP" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Text.SubtitleStrong"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Лучшие результаты" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Скорость" />

                    <TextView
                        android:id="@+id/tvBestSpeed"
                        style="@style/Text.SubtitleStrong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 слов/мин" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Чёткость" />

                    <TextView
                        android:id="@+id/tvBestClarity"
                        style="@style/Text.SubtitleStrong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0%" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Понимание" />

                    <TextView
                        android:id="@+id/tvBestUnderstanding"
                        style="@style/Text.SubtitleStrong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0%" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            style="@style/Text.SubtitleStrong"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Данные пользователя" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/stroke_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/Text.BodySecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvEmail"
                        style="@style/Text.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="email@example.com" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmailEdit"
                        style="@style/Text.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textEmailAddress"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnEditEmail"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Редактировать email"
                        android:padding="6dp"
                        android:src="@drawable/ic_edit" />

                    <ImageButton
                        android:id="@+id/btnSaveEmail"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Сохранить email"
                        android:padding="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnCancelEmail"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Отменить email"
                        android:padding="6dp"
                        android:src="@drawable/ic_close"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/stroke_soft" />

                <TextView
                    style="@style/Text.BodySecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пароль" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPassword"
                        style="@style/Text.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="••••••••" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordEdit"
                        style="@style/Text.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textPassword"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnEditPassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Редактировать пароль"
                        android:padding="6dp"
                        android:src="@drawable/ic_edit" />

                    <ImageButton
                        android:id="@+id/btnSavePassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Сохранить пароль"
                        android:padding="6dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnCancelPassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_panel_soft"
                        android:contentDescription="Отменить пароль"
                        android:padding="6dp"
                        android:src="@drawable/ic_close"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnLogout"
            style="@style/ButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="Выйти из профиля"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>
