<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_playful">

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_panel_soft"
        android:elevation="10dp"
        android:padding="10dp"
        android:layout_margin="10dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnRaces"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Забеги"
            android:textSize="12sp"
            android:drawableTop="@drawable/ic_gamepad"
            android:drawablePadding="6dp"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Button
            android:id="@+id/btnAcademy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Академия"
            android:textSize="12sp"
            android:drawableTop="@drawable/ic_graduation_cap"
            android:drawablePadding="6dp"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Профиль"
            android:textSize="12sp"
            android:drawableTop="@drawable/ic_profile_avatar"
            android:drawablePadding="6dp"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</LinearLayout>
