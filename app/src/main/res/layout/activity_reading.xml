<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start"
        android:src="@drawable/ic_arrow_back"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Назад"
        android:padding="8dp" />

    <RelativeLayout
        android:id="@+id/characterTrack"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/obstacle1"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentTop="true"
            android:layout_marginTop="20dp"
            android:layout_marginStart="95dp"
            android:background="#FF8A65" />

        <View
            android:id="@+id/obstacle2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="170dp"
            android:background="#FF7043" />

        <View
            android:id="@+id/obstacle3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="22dp"
            android:layout_marginStart="260dp"
            android:background="#FF5722" />

        <ImageView
            android:id="@+id/ivCharacter"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Персонаж"
            android:src="@drawable/stickman_face" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp"
        android:layout_marginTop="16dp"
        android:background="#F5F5F5"
        android:elevation="8dp">

        <TextView
            android:id="@+id/tvCurrentLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нажмите кнопку микрофона, чтобы начать чтение"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:padding="20dp"
            android:minHeight="140dp"
            android:background="@color/white"
            android:elevation="4dp"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnMicrophone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Начать чтение"
            style="@style/ButtonModern" />

    </LinearLayout>

</LinearLayout>
